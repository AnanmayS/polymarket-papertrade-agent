APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
DATABASE_URL=sqlite:///./backend/demo.db
POSTGRES_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/polymarket_papertrade
LOCAL_DATABASE_URL=sqlite:///./backend/demo.db
REDIS_URL=redis://redis:6379/0
USE_REDIS=false
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
USE_LIVE_POLYMARKET_DATA=true
SEED_DEMO_DATA=true
MARKET_TIMEZONE=America/New_York
RESOLUTION_WINDOW_DAYS=7
INITIAL_BANKROLL=10000
MIN_LIQUIDITY=25000
MIN_VOLUME=10000
MAX_SPREAD=0.08
MIN_HOURS_TO_RESOLUTION=2
MAX_HOURS_TO_RESOLUTION=336
MIN_CONFIDENCE=0.35
MIN_EDGE_TO_TRADE=0.025
MAX_POSITION_SIZE_PCT=0.03
MAX_MARKET_EXPOSURE_PCT=0.06
MAX_CATEGORY_EXPOSURE_PCT=0.2
MAX_DAILY_LOSS_PCT=0.05
MAX_OPEN_TRADES=10
FRACTIONAL_KELLY=0.25
DEFAULT_SIGNAL_MODE=heuristic
SCHEDULER_ENABLED=true
AUTO_RUN_ON_STARTUP=true
SCAN_INTERVAL_SECONDS=300
SIGNAL_INTERVAL_SECONDS=600
TRADE_INTERVAL_SECONDS=900
SETTLEMENT_INTERVAL_SECONDS=1800
AGENT_CYCLE_INTERVAL_SECONDS=300
